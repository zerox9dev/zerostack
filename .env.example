# Supabase — заполни из дашборда проекта (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — server-only, bypasses RLS. Used by /app/admin to
# read waitlist + feedback. NEVER expose to the client, NEVER prefix
# with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated list of admin emails. These accounts can access
# /app/admin (waitlist + feedback views). Match by Supabase Auth email.
ADMIN_EMAILS=

# Public site URL — used for canonical, OpenGraph, sitemap, robots.
# In Vercel preview/prod this defaults to https://${VERCEL_URL} when unset.
# Set explicitly in production to your stable domain.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
